<Window x:Class="Human_Resources.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OPAL HANDS HOME HEALTH CARE" Height="650" Width="1100" 
        Icon="pack://application:,,,/Assets/Logo.ico"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4D55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SubMenuButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="50,0,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F2F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="GridMenu" Width="235"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2E3137" Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Button Style="{StaticResource MenuButtonStyle}" Click="BtnToggle_Click">
                            <Grid Width="200" HorizontalAlignment="Left">
                                <TextBlock Text="☰" FontSize="22" Margin="18,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <StackPanel x:Name="pnlDefinitionsContainer">
                            <Button Style="{StaticResource MenuButtonStyle}" Click="BtnDefinitions_Click">
                                <Grid Width="235">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📰" FontSize="20" Margin="18,0,25,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtDefinitions" Text="Definitions" FontSize="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtFlecha" Text="⌵" HorizontalAlignment="Right" Margin="0,0,20,0" VerticalAlignment="Center" Foreground="White"/>
                                </Grid>
                            </Button>
                            <StackPanel x:Name="pnlSubMenuDefinitions" Visibility="Collapsed" Background="#3E4249">
                                <Button Content="  ⭕ States" Style="{StaticResource SubMenuButtonStyle}"      Margin="20,0,0,0" Click="BtnFrmGeoState_Click"/>
                                <Button Content="  ⭕ Cities" Style="{StaticResource SubMenuButtonStyle}"      Margin="20,0,0,0" Click="BtnFrmGeoCity_Click"/>
                                <Button Content="  ⭕ Regions" Style="{StaticResource SubMenuButtonStyle}"     Margin="20,0,0,0" Click="BtnFrmGeoRegion_Click"/>
                                <Separator Background="#DCDCDC" Height="1" Margin="5,2" />
                                <Button Content="  ⭕ Inmigration" Style="{StaticResource SubMenuButtonStyle}" Margin="20,0,0,0" Click="BtnFrmDocsInmigration_Click"/>
                                <Button Content="  ⭕ Languages" Style="{StaticResource SubMenuButtonStyle}"   Margin="20,0,0,0" Click="BtnFrmLanguage_Click"/>
                                <Separator Background="#DCDCDC" Height="1" Margin="5,2" />
                                <Button Content="  ⭕ Payroll" Style="{StaticResource SubMenuButtonStyle}"     Margin="20,0,0,0" Click="BtnFrmDocsPayroll_Click"/>
                                <Button Content="  ⭕ Banks" Style="{StaticResource SubMenuButtonStyle}"       Margin="20,0,0,0" Click="BtnFrmBanks_Click"/>
                                <Button Content="  ⭕ Payment" Style="{StaticResource SubMenuButtonStyle}"     Margin="20,0,0,0" Click="BtnFrmBanksMethod_Click"/>
                                <Separator Background="#DCDCDC" Height="1" Margin="5,2" />
                                <Button Content="  ⭕ Departments" Style="{StaticResource SubMenuButtonStyle}" Margin="20,0,0,0" Click="BtnFrmDepartment_Click"/>
                                <Button Content="  ⭕ Licenses"    Style="{StaticResource SubMenuButtonStyle}" Margin="20,0,0,0" Click="BtnFrmDepLicense_Click"/>
                            </StackPanel>
                        </StackPanel>

                        
                        <StackPanel x:Name="pnlDocumentContainer">
                            <Button Style="{StaticResource MenuButtonStyle}" Click="BtnDocument_Click">
                                <Grid Width="235">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗂️" FontSize="20" Margin="18,0,25,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtDocument" Text="Documents" FontSize="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtFlecha5" Text="⌵" HorizontalAlignment="Right" Margin="0,0,20,0" VerticalAlignment="Center" Foreground="White"/>
                                </Grid>
                            </Button>
                            <StackPanel x:Name="pnlSubMenuDocument" Visibility="Collapsed" Background="#3E4249">
                                <Button Content="  ⭕ Required"  Style="{StaticResource SubMenuButtonStyle}" Margin="20,0,0,0" Click="BtnFrmDocsRequired_Click"/>
                                <Button Content="  ⭕ Aditional" Style="{StaticResource SubMenuButtonStyle}" Margin="20,0,0,0" Click="BtnFrmDocsAdditional_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="pnlStaffContainer">
                            <Button Style="{StaticResource MenuButtonStyle}" Click="BtnStaff_Click">
                                <Grid Width="235">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👩‍⚕️" FontSize="20" Margin="18,0,25,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtStaff" Text="Company Staff" FontSize="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtFlecha4" Text="⌵" HorizontalAlignment="Right" Margin="0,0,20,0" VerticalAlignment="Center" Foreground="White"/>
                                </Grid>
                            </Button>
                            <StackPanel x:Name="pnlSubMenuStaff" Visibility="Collapsed" Background="#3E4249">
                                <Button Content="  ⭕ Staff"     Style="{StaticResource SubMenuButtonStyle}"              Margin="20,0,0,0" Click="BtnFrmStaff_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="pnlStaffPost">
                            <Button Style="{StaticResource MenuButtonStyle}" Click="BtnStaffPost_Click">
                                <Grid Width="235">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗓️" FontSize="20" Margin="18,0,25,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtPost" Text="Post Documents" FontSize="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtFlecha2" Text="⌵" HorizontalAlignment="Right" Margin="0,0,20,0" VerticalAlignment="Center" Foreground="White"/>
                                </Grid>
                            </Button>
                            <StackPanel x:Name="pnlSubMenuStaffPost" Visibility="Collapsed" Background="#3E4249">
                                <Button Content="  ⭕ Documents" Style="{StaticResource SubMenuButtonStyle}"              Margin="20,0,0,0" Click="BtnFrmStaffDocsRequired_Click"/>
                                <Button Content="  ⭕ Docs Additional" Style="{StaticResource SubMenuButtonStyle}"        Margin="20,0,0,0" Click="BtnFrmStaffDocsAditional_Click"/>
                            </StackPanel>
                        </StackPanel>


                        <StackPanel x:Name="pnlFindContainer">
                            <Button Style="{StaticResource MenuButtonStyle}" Click="BtnFind_Click">
                                <Grid Width="235">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔍" FontSize="20" Margin="18,0,25,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtFind" Text="Expired Docs" FontSize="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtFlecha6" Text="⌵" HorizontalAlignment="Right" Margin="0,0,20,0" VerticalAlignment="Center" Foreground="White"/>
                                </Grid>
                            </Button>
                            <StackPanel x:Name="pnlSubMenuFind" Visibility="Collapsed" Background="#3E4249">
                                <Button Content="  ⭕ Status Docs" Style="{StaticResource SubMenuButtonStyle}"            Margin="20,0,0,0" Click="BtnFrmFindStaff_Click"/>
                                <Button Content="  ⭕ Status Docs Additional" Style="{StaticResource SubMenuButtonStyle}" Margin="20,0,0,0" Click="BtnFrmFindStaffAdditional_Click"  />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="pnlProspectsContainer">
                            <Button Style="{StaticResource MenuButtonStyle}" Click="BtnProspects_Click">
                                <Grid Width="235">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👤" FontSize="20" Margin="18,0,25,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtProspects" Text="Prospects" FontSize="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtFlechaProspects" Text="⌵" HorizontalAlignment="Right" Margin="0,0,20,0" VerticalAlignment="Center" Foreground="White"/>
                                </Grid>
                            </Button>
                            <StackPanel x:Name="pnlSubMenuProspects" Visibility="Collapsed" Background="#3E4249">
                                <Button Content="  ⭕ Applicants" Style="{StaticResource SubMenuButtonStyle}" Margin="20,0,0,0" Click="BtnFrmApplicants_Click"/>
                                <Button Content="  ⭕ Required Docs" Style="{StaticResource SubMenuButtonStyle}" Margin="20,0,0,0" Click="BtnFrmProspectsDocs_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="pnlSetup">
                            <Button Style="{StaticResource MenuButtonStyle}" Click="BtnSetup_Click">
                                <Grid Width="235">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙️" FontSize="20" Margin="18,0,25,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtSetup" Text="Setup" FontSize="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtFlecha3" Text="⌵" HorizontalAlignment="Right" Margin="0,0,20,0" VerticalAlignment="Center" Foreground="White"/>
                                </Grid>
                            </Button>
                            <StackPanel x:Name="pnlSubMenuSetup" Visibility="Collapsed" Background="#3E4249">
                                <Button Content="  ⭕ Company" Style="{StaticResource SubMenuButtonStyle}" Margin="20,0,0,0" Click="BtnFrmCompany_Click"/>
                                <Button Content="  ⭕ Users"   Style="{StaticResource SubMenuButtonStyle}" Margin="20,0,0,0" Click="BtnFrmCfgUsers_Click"  />
                                <Button Content="  ⭕ Auth. Devices" Style="{StaticResource SubMenuButtonStyle}" Margin="20,0,0,0" Click="BtnFrmAuthorizedDevices_Click"  />
                            </StackPanel>
                        </StackPanel>


                        <!-- <Button Style="{StaticResource MenuButtonStyle}">
                            <StackPanel Orientation="Horizontal" Width="235">
                                <TextBlock Text="⚙️" FontSize="20" Margin="18,0,25,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtConfig" Text="Configuración" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        --> 


                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="White" Grid.Row="0">
                <TextBlock Text="Humans Resources" VerticalAlignment="Center" Margin="20,0" FontSize="18" FontWeight="SemiBold" Foreground="#2E3137"/>
            </Border>

            <TabControl x:Name="tcPrincipal" Grid.Row="1" Background="#F4F7F9" BorderThickness="0" Margin="5">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="HeaderTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                        <Button Content="✕" Foreground="Gray" Background="Transparent" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Click="BtnCerrarTab_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
            </TabControl>
        </Grid>
    </Grid>
</Window>