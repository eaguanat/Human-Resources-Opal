<Page x:Class="Human_Resources.Forms.frmGeoLocator"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      mc:Ignorable="d" 
      Title="GeoLocator" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Cabecera Azul -->
            <RowDefinition Height="*"/>
            <!-- Contenido Principal -->
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
            <DockPanel>
                <TextBlock x:Name="lblTitulo" 
                           Text="GEOLOCATOR - SEARCH" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Fila para los controles de filtro -->
                <RowDefinition Height="*"/>
                <!-- Fila para resultados (DataGrid / Mapa) -->
                <RowDefinition Height="Auto"/>
                <!-- Fila para los botones de acción -->
            </Grid.RowDefinitions>

            <!-- FILTROS DE BÚSQUEDA (SIEMPRE VISIBLES, se deshabilitan) -->
            <Border x:Name="bdrFilterControls" Grid.Row="0" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                        <TextBlock Text="Origin" FontSize="14" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbOrigin"
                      Height="25" Margin="0,5,0,0"
                      SelectionChanged="cmbOrigin_SelectionChanged" 
                      DisplayMemberPath="Description" SelectedValuePath="Id"/>

                        <CheckBox x:Name="chkActive" 
                      Content="Active Only" 
                      IsChecked="True" 
                      FontSize="11" 
                      Foreground="#2C3E50"
                      FontWeight="SemiBold"
                      Margin="2,2,0,5"
                      Cursor="Hand"
                      VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                        <TextBlock Text="Department" FontSize="14" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbDepartment"
                      Height="25" Margin="0,5"
                      DisplayMemberPath="Description" SelectedValuePath="Id"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3" Margin="5">
                        <TextBlock Text="Address to Locate" FontSize="14" FontWeight="Bold"/>
                        <TextBox x:Name="txtAddress"
                     Height="25" Margin="0,5"
                     MaxLength="200" CharacterCasing="Upper"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="5" Margin="5">
                        <TextBlock Text="Top Results" FontSize="14" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbTopX"
                      Height="25" Margin="0,5"
                      DisplayMemberPath="Description" SelectedValuePath="Id"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENIDO DINÁMICO (MAPA + RESULTADOS o MENSAJE INICIAL) -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <!-- PANEL DE RESULTADOS (MAPA + DATAGRID) -->
                <Grid x:Name="pnlResultados" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="7*"/>
                        <!-- Mapa -->
                        <ColumnDefinition Width="3*"/>
                        <!-- DataGrid -->
                    </Grid.ColumnDefinitions>

                    <!-- MAPA (WebView2) -->
                    <Border Grid.Column="0" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,10,0">
                        <wv2:WebView2 x:Name="webView" Source="about:blank" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Border>

                    <!-- DATAGRID DE RESULTADOS -->
                    <Border Grid.Column="1" BorderBrush="#DEE2E6" BorderThickness="1">
                        <DataGrid x:Name="dgResultados" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True" 
                                  SelectionMode="Single"
                                  Background="Transparent" 
                                  BorderThickness="0" 
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column" 
                                  FontSize="14" 
                                  RowHeight="25"
                                  AlternationCount="2"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F9F9FB"
                                  SelectionChanged="dgResultados_SelectionChanged"
                                  MouseDoubleClick="dgResultados_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="(mi)" Binding="{Binding DistanceMiles, StringFormat='{}{0:N2}'}" Width="40"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- MENSAJE INICIAL (cuando no hay búsqueda aún) -->
                <TextBlock x:Name="txtInitialMessage"
                           Text="Enter search criteria above and click 'Search' to find entities near you."
                           Visibility="Visible"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="20" Foreground="#555" TextAlignment="Center" TextWrapping="Wrap"
                           Margin="50"/>
            </Grid>

            <!-- BOTONES DE ACCIÓN (Buscar, Reset, Exit, Back - visibilidad controlada por C#) -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="BtnBuscar" 
                        Content="_Search" 
                        Click="BtnBuscar_Click"
                        Width="120" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Background="#2ecc71" Foreground="White" Margin="5"/>
                <Button x:Name="BtnResetFiltro" 
                        Content="_Reset" 
                        Click="BtnResetFiltro_Click"
                        Width="120" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Background="#F39C12" Foreground="White" Margin="5"/>
                <Button x:Name="BtnExit" 
                        Content="_Exit" 
                        Click="BtnExit_Click"
                        Width="120" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Background="#95a5a6" Foreground="White" Margin="5"/>

                <!-- Botón de "Back" para volver de resultados a filtros -->
                <Button x:Name="BtnBack" 
                        Content="_Back" 
                        Click="BtnBack_Click"
                        Width="120" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Background="#2ecc71" Foreground="White" Margin="5" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>