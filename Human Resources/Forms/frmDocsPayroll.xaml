<Page x:Class="Human_Resources.Forms.frmDocsPayroll"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Human_Resources.Forms"
        mc:Ignorable="d"
        Height="450" Width="800"
        Title="frmDocsPayroll">

    <Grid Margin="20">
        <Border Background="White" CornerRadius="15" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="lblTitulo" Text="Payroll Type" FontSize="24" 
                           FontWeight="Bold" Foreground="#2E3137" Margin="0,0,0,20"/>

                <Button Content="🖨️" 
                                Style="{StaticResource MenuButtonStyle}" 
                                Name="btnPrint"
                                Click="BtnPrint_Click" Height="35" 
                                FontSize="20" 
                                Background="#95a5a6" Foreground="White" 
                                BorderThickness="0" Margin="666,16,0,1"
                        />

                <Grid x:Name="GridListado" Grid.Row="1" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgListado" 
                        AutoGenerateColumns="False" 
                        IsReadOnly="True" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        GridLinesVisibility="None"
                        HeadersVisibility="Column" 
                        FontSize="20" 
                        RowHeight="25"
                        AlternationCount="2"
                        RowBackground="White"
                        AlternatingRowBackground="#F9F9FB">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Existing Records" 
                                                Binding="{Binding Description}" 
                                                FontSize="15" 
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">

                        <Button Content="_Add" 
                                Name="BtnAdd"
                                Style="{StaticResource MenuButtonStyle}"    
                                FontSize="15"
                                Click="BtnAdd_Click" 
                                Width="90" Height="35" 
                                Margin="5" 
                                Background="#2ecc71" Foreground="White" 
                         />

                        <Button Content="_Modify" 
                                Name="BtnModify"
                                Style="{StaticResource MenuButtonStyle}"    
                                FontSize="15"
                                Click="BtnModify_Click" 
                                Width="90" Height="35" 
                                Background="#3498db" Foreground="White" 
                                BorderThickness="0" Margin="5"
                         />

                        <Button Content="_Delete" 
                                Name="BtnDelete"
                                Click="BtnDelete_Click" 
                                Style="{StaticResource MenuButtonStyle}"    
                                FontSize="15"
                                Width="90" Height="35" 
                                Background="#e74c3c" Foreground="White" 
                                BorderThickness="0" Margin="5"
                        />
                        <Button Content="_Exit" 
                                Name="BtnExit"
                                Style="{StaticResource MenuButtonStyle}"    
                                FontSize="15"
                                Click="BtnExit_Click" 
                                Width="90" Height="35" 
                                Background="#95a5a6" Foreground="White" 
                                BorderThickness="0" Margin="5"
                        />
                    </StackPanel>
                </Grid>

                <Grid x:Name="GridEdicion" Grid.Row="1" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                        <TextBlock Text="Enter the Payroll Type." 
                                   Foreground="#666" 
                                   Margin="0,0,0,5" FontSize="16"/>
                        <TextBox x:Name="txtDescription" 
                                 Height="45" Padding="10,0" 
                                 MaxLength="40"
                                 VerticalContentAlignment="Center" 
                                 FontSize="18"
                                 CharacterCasing="Upper" 
                                 BorderThickness="0,0,0,2" 
                                 BorderBrush="#3498db" Background="#F4F4F4"/>

                        <StackPanel Orientation="Horizontal" Margin="0,40,0,0" HorizontalAlignment="Center">
                            <Button Content="_Update" 
                                    Name="BtnUpdate"
                                    Click="BtnUpdate_Click" 
                                    Style="{StaticResource MenuButtonStyle}"    
                                    FontSize="15"
                                    Width="130" Height="40" 
                                    Background="#2E3137" Foreground="White" 
                                    BorderThickness="0" Margin="10"
                            />
                            <Button Content="_Home" 
                                    Name="BtnHome"
                                    Style="{StaticResource MenuButtonStyle}"    
                                    FontSize="15"
                                    Click="BtnVolverInicio_Click" 
                                    Width="130" Height="40" 
                                    Background="Transparent" Foreground="#2E3137" 
                                    BorderThickness="1" 
                                    BorderBrush="#2E3137" 
                                    Margin="10"
                            />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>

