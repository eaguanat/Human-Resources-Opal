<Page x:Class="Human_Resources.Forms.frmDocsRequired"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:Human_Resources"
      mc:Ignorable="d"
      Title="frmDocsRequired" Height="450" Width="800">

    <Grid Margin="20">
        <Border Background="White" CornerRadius="15" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="lblTitulo" Text="Definition of Documents" FontSize="24" 
                           FontWeight="Bold" Foreground="#2E3137" Margin="0,0,0,10"/>

                <Button Content="🖨️" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Name="btnPrint"
                        Click="BtnPrint_Click" Height="35" 
                        FontSize="20" 
                        Background="#95a5a6" Foreground="White" 
                        BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Top" Width="50"/>

                <Grid x:Name="GridListado" Grid.Row="1" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal"
                                Margin="0,0,0,15">
                        <TextBlock Text="Department:" 
                                   VerticalAlignment="Center" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="#666" 
                                   Margin="0,0,10,0"/>

                        <ComboBox x:Name="cmbFiltroDpto" Width="250" Height="30" 
                                  SelectionChanged="cmbFiltroDpto_SelectionChanged"
                                  VerticalContentAlignment="Center" FontSize="14"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal" 
                                Margin="0,0,0,15">
                        <TextBlock Text="Section:" 
                                   VerticalAlignment="Center" 
                                   FontWeight="Bold"
                                   FontSize="14" 
                                   Foreground="#666" 
                                   Margin="0,0,10,0"/>

                        <ComboBox x:Name="cmbSection" Width="250" Height="30" 
                                  SelectionChanged="cmbSection_SelectionChanged"
                                  VerticalContentAlignment="Center" FontSize="14"/>
                    </StackPanel>

                    <DataGrid x:Name="dgDocuments" 
                              Grid.Row="1" Grid.ColumnSpan="2"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              Background="Transparent" 
                              BorderThickness="0" 
                              GridLinesVisibility="None"
                              HeadersVisibility="Column" 
                              FontSize="16" 
                              RowHeight="25"
                              AlternationCount="2"
                              RowBackground="White"
                              AlternatingRowBackground="#F9F9FB">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Document Description" 
                                                Binding="{Binding Description}" 
                                                Width="*" />
                            <DataGridCheckBoxColumn Header="( R )" 
        Binding="{Binding Required}" 
        IsReadOnly="True"
        Width="50">
                                <DataGridCheckBoxColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </Style>
                                </DataGridCheckBoxColumn.HeaderStyle>

                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="_Add" Name="BtnAdd" IsEnabled="False" Click="BtnAdd_Click" Style="{StaticResource MenuButtonStyle}" FontSize="15" Width="90" Height="35" Margin="5" Background="#2ecc71" Foreground="White"/>
                        <Button Content="_Modify" Name="BtnModify" IsEnabled="False" Click="BtnModify_Click" Style="{StaticResource MenuButtonStyle}" FontSize="15" Width="90" Height="35" Margin="5" Background="#3498db" Foreground="White"/>
                        <Button Content="_Delete" Name="BtnDelete" IsEnabled="False" Click="BtnDelete_Click" Style="{StaticResource MenuButtonStyle}" FontSize="15" Width="90" Height="35" Margin="5" Background="#e74c3c" Foreground="White"/>
                        <Button Content="_Exit" Name="BtnExit" IsEnabled="True" Click="BtnExit_Click" Style="{StaticResource MenuButtonStyle}" FontSize="15" Width="90" Height="35" Margin="5" Background="#95a5a6" Foreground="White"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="GridEdicion" Grid.Row="1" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" 
                                HorizontalAlignment="Center" 
                                Width="700">
                        <TextBlock Text="Selected Department:" Foreground="#666" Margin="0,0,0,2" FontSize="14"/>
                        <TextBlock x:Name="lblFindA" Text="---" Foreground="#2E3137" 
                                   FontWeight="Bold" FontSize="18" Margin="0,0,0,25"/>

                        <TextBlock Text="Enter the Doc Description" Foreground="#666" Margin="0,0,0,5" FontSize="16"/>
                        <TextBox x:Name="txtDescription" 
                                 Height="45" 
                                 Padding="10,0" 
                                 VerticalContentAlignment="Center" 
                                 FontSize="18"
                                 CharacterCasing="Upper" 
                                 BorderThickness="0,0,0,2" 
                                 BorderBrush="#3498db" 
                                 Background="#F4F4F4"/>

                        <CheckBox x:Name="CbRequired" 
                                  Content="Is this document required?" 
                                  FontSize="16" 
                                  Margin="0,15,0,0"
                                  Foreground="#2E3137"
                                  VerticalContentAlignment="Center"
                                  Cursor="Hand"/>

                        <StackPanel Orientation="Horizontal" Margin="0,40,0,0" HorizontalAlignment="Center">
                            <Button Content="_Update" Name="BtnUpdate" Click="BtnUpdate_Click" 
                                    Style="{StaticResource MenuButtonStyle}" FontSize="15" Width="130" Height="40" Background="#2E3137" Foreground="White" Margin="10"/>
                            <Button Content="_Home" Name="BtnHome" Click="BtnVolverInicio_Click" 
                                    Style="{StaticResource MenuButtonStyle}" FontSize="15" Width="130" Height="40" Background="Transparent" Foreground="#2E3137" BorderThickness="1" BorderBrush="#2E3137" Margin="10"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>