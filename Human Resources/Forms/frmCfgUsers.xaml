<Page x:Class="Human_Resources.Forms.frmCfgUsers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="User Management" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Cabecera Azul -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar con Buscador -->
            <RowDefinition Height="*"/>
            <!-- Contenido -->
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
            <DockPanel>
                <TextBlock x:Name="lblTitulo" 
                           Text="USER MANAGEMENT" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="10">
            <DockPanel>
                <StackPanel x:Name="pnlSearch" Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="Search Full Name:" 
                               FontSize="18"
                               VerticalAlignment="Center" 
                               Margin="0,0,10,0"/>
                    <TextBox x:Name="txtSearch" 
                             Width="400" Height="25" 
                             VerticalContentAlignment="Center" 
                             FontSize="18"
                             CharacterCasing="Upper" 
                             TextChanged="txtSearch_TextChanged"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- AREA DE TRABAJO -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- LISTADO (DataGrid) -->
            <Grid x:Name="GridListado">
                <DataGrid x:Name="dgListado" 
                        AutoGenerateColumns="False" 
                        IsReadOnly="True" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        GridLinesVisibility="None"
                        HeadersVisibility="Column" 
                        FontSize="16" 
                        RowHeight="25"
                        AlternationCount="2"
                        RowBackground="White"
                        AlternatingRowBackground="#F9F9FB"
                        SelectionMode="Single">

                    <DataGrid.Columns>
                        <DataGridTextColumn     Header="Full Name"      Binding="{Binding FullName}"     Width="2*"/>
                        <DataGridTextColumn     Header="Email"          Binding="{Binding email}"        Width="2*"/>
                        <DataGridCheckBoxColumn Header="Active"         Binding="{Binding Active}"       Width="55"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom" >

                <Button x:Name="BtnAdd" 
                        Content="_Add" 
                        Click="BtnAdd_Click"
                        Width="90" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Margin="5" 
                        Background="#2ecc71" Foreground="White" 
                        />
                <Button x:Name="BtnModify" 
                        Content="_Modify" 
                        Click="BtnModify_Click"
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Width="90" Height="35" 
                        Background="#3498db" Foreground="White" 
                        BorderThickness="0" Margin="5"
                        />
                <Button x:Name="BtnDelete" 
                        Click="BtnDelete_Click"
                        Content="_Delete" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Width="90" Height="35" 
                        Background="#e74c3c" Foreground="White" 
                        BorderThickness="0" Margin="5"
                        />
                <Button x:Name="BtnExit" 
                        Content="_Exit" 
                        Click="BtnExit_Click"
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Width="90" Height="35" 
                        Background="#95a5a6" Foreground="White" 
                        BorderThickness="0" Margin="5"
                        />
            </StackPanel>

            <!-- EDICION (TabControl) -->
            <Grid x:Name="GridEdicion" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TabControl x:Name="tcUser" Grid.Row="0">
                    <!-- TAB 1: User Details -->
                    <TabItem Header="User Details" FontSize="16">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                                <TextBlock Text="Full Name" FontSize="15" FontWeight="Bold"/>
                                <TextBox x:Name="txtFullName"
                                         FontSize="15" MaxLength="50" CharacterCasing="Upper"
                                         BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                         Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="5">
                                <TextBlock Text="User Name" FontSize="15" FontWeight="Bold"/>
                                <TextBox x:Name="txtName"
                                         FontSize="15" MaxLength="50" 
                                         BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                         Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="3" Margin="5">
                                <TextBlock Text="Phone" FontSize="15" FontWeight="Bold"/>
                                <TextBox x:Name="txtPhone"
                                         FontSize="15" MaxLength="20"
                                         BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                         Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db"/>
                            </StackPanel>


                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                                <TextBlock Text="Email" FontSize="15" FontWeight="Bold"/>
                                <TextBox x:Name="txtEmail"
                                         FontSize="15" MaxLength="50" CharacterCasing="Lower"
                                         BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                         Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="3" Margin="5">
                                <TextBlock Text="Job Description" FontSize="15" FontWeight="Bold"/>
                                <TextBox x:Name="txtDescriptionJob"
                                         FontSize="15" MaxLength="50" CharacterCasing="Upper"
                                         BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                         Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="2" Margin="5">
                                <TextBlock Text="Password" FontSize="15" FontWeight="Bold"/>
                                <PasswordBox x:Name="pbPassword"
                                             FontSize="15" MaxLength="50"
                                             BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                             Padding="2,5" VerticalContentAlignment="Center" >
                                    <PasswordBox.ToolTip>
                                        <TextBlock>Leave blank to keep current password. Enter new password to change it.</TextBlock>
                                    </PasswordBox.ToolTip>
                                </PasswordBox>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="3" Margin="5">
                                <TextBlock Text="Confirm Password" FontSize="15" FontWeight="Bold"/>
                                <PasswordBox x:Name="pbConfirmPassword"
                                             FontSize="15" MaxLength="50"
                                             BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                             Padding="2,5" VerticalContentAlignment="Center" />
                            </StackPanel>

                            
                        </Grid>
                    </TabItem>

                    <!-- TAB 2: Access Permissions -->
                    <TabItem Header="Access Permissions" FontSize="16">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <GroupBox Header="Granted Modules" 
                                      Background="Transparent" 
                                      BorderThickness="0" 
                                      FontSize="15"
                                      FontWeight="Bold"
                                      VerticalAlignment="Stretch">
                                <ListBox x:Name="lstAccessModules" 
                                         HorizontalAlignment="Stretch"
                                         Height="Auto" 
                                         BorderThickness="0,0,0,1" 
                                         BorderBrush="Transparent"
                                         ScrollViewer.CanContentScroll="True">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Description}" VerticalAlignment="Center" Margin="5,0,0,0" FontWeight="SemiBold"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>
                        </Grid>
                    </TabItem>
                </TabControl>

                <Grid Grid.Row="1" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="chkActive"
                              Grid.Row="4" Grid.Column="0"
                              Content="User is Active"
                              FontSize="15" Foreground="Red" IsChecked="True"
                              VerticalAlignment="Center" FontWeight="Bold" Margin="5"/>     

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnUpdate" 
                                Content="_Update" 
                                Click="BtnUpdate_Click" 
                                Style="{StaticResource MenuButtonStyle}"    
                                FontSize="15"
                                Width="130" Height="40" 
                                Background="#2E3137" Foreground="White" 
                                Margin="10,0"/>

                        <Button x:Name="BtnHome" 
                                Content="_Home" 
                                Style="{StaticResource MenuButtonStyle}"    
                                FontSize="15"
                                Click="BtnVolverInicio_Click" 
                                Width="130" Height="40" 
                                Background="Transparent" Foreground="#2E3137" 
                                BorderThickness="1" BorderBrush="#2E3137" 
                                Margin="10,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>