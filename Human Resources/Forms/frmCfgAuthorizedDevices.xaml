<Page x:Class="Human_Resources.Forms.frmCfgAuthorizedDevices"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Authorized Devices" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Cabecera Azul -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar con Buscador -->
            <RowDefinition Height="*"/>
            <!-- Contenido -->
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
            <DockPanel>
                <TextBlock x:Name="lblTitulo" 
                           Text="AUTHORIZED DEVICES MANAGEMENT" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="10">
            <DockPanel>
                <StackPanel x:Name="pnlSearch" Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="Search Device Name:" 
                               FontSize="18"
                               VerticalAlignment="Center" 
                               Margin="0,0,10,0"/>
                    <TextBox x:Name="txtSearch" 
                             Width="400" Height="25" 
                             VerticalContentAlignment="Center" 
                             FontSize="18"
                             CharacterCasing="Upper" 
                             TextChanged="txtSearch_TextChanged"/>
                </StackPanel>
                
            </DockPanel>
        </Border>

        <!-- AREA DE TRABAJO -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- LISTADO (DataGrid) -->
            <Grid x:Name="GridListado">
                <DataGrid x:Name="dgListado" 
                        AutoGenerateColumns="False" 
                        IsReadOnly="True" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        GridLinesVisibility="None"
                        HeadersVisibility="Column" 
                        FontSize="16" 
                        RowHeight="25"
                        AlternationCount="2"
                        RowBackground="White"
                        AlternatingRowBackground="#F9F9FB"
                        SelectionMode="Single">

                    <DataGrid.Columns>
                        <DataGridTextColumn     Header="Device Name"      Binding="{Binding DeviceName}"     Width="2*"/>
                        <DataGridTextColumn     Header="Reg. Date"        Binding="{Binding RegistrationDate, StringFormat='{}{0:MM/dd/yyyy}'}" Width="*"/>
                        <DataGridCheckBoxColumn Header="Active"           Binding="{Binding IsActive}"       Width="55"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom" >

                <Button x:Name="BtnAdd" 
                        Content="_Add" 
                        Click="BtnAdd_Click"
                        Width="90" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Margin="5" 
                        Background="#2ecc71" Foreground="White" 
                        />
                <Button x:Name="BtnModify" 
                        Content="_Modify" 
                        Click="BtnModify_Click"
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Width="90" Height="35" 
                        Background="#3498db" Foreground="White" 
                        BorderThickness="0" Margin="5"
                        />
                <Button x:Name="BtnDelete" 
                        Click="BtnDelete_Click"
                        Content="_Delete" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Width="90" Height="35" 
                        Background="#e74c3c" Foreground="White" 
                        BorderThickness="0" Margin="5"
                        />
                <Button x:Name="BtnExit" 
                        Content="_Exit" 
                        Click="BtnExit_Click"
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Width="90" Height="35" 
                        Background="#95a5a6" Foreground="White" 
                        BorderThickness="0" Margin="5"
                        />
            </StackPanel>

            <!-- EDICION -->
            <Grid x:Name="GridEdicion" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="20,20,05,0">
                    <TextBlock Text="Device Name" FontSize="15" FontWeight="Bold"/>
                    <TextBox x:Name="txtDeviceName"
                             FontSize="15" MaxLength="40" CharacterCasing="Upper"
                             BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                             Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="3" Margin="20,20,20,0">
                    <TextBlock Text="Registration Date" FontSize="15" FontWeight="Bold" />
                    <DatePicker x:Name="dpRegistrationDate"
                                FontSize="15" IsEnabled="False"
                                BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="#F0F0F0"
                                Padding="2,5" VerticalContentAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="20,0,20,0">
                    <TextBlock Text="Device ID (Hash)" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtDeviceHash"
                             FontSize="15" IsReadOnly="True"
                             BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="#F0F0F0"
                             Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                </StackPanel>



                    

                <Grid Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <CheckBox x:Name="chkIsActive"
                                  Content="Device is Active"
                                  FontSize="15" Foreground="Red" IsChecked="True"
                                  VerticalAlignment="Center" FontWeight="Bold" Margin="0,20,0,20"/>
                        
                        <Button x:Name="BtnUpdate" 
                                Content="_Update" 
                                Click="BtnUpdate_Click" 
                                Style="{StaticResource MenuButtonStyle}"    
                                FontSize="15"
                                Width="130" Height="40" 
                                Background="#2E3137" Foreground="White" 
                                Margin="10,0"/>

                        <Button x:Name="BtnHome" 
                                Content="_Home" 
                                Style="{StaticResource MenuButtonStyle}"    
                                FontSize="15"
                                Click="BtnVolverInicio_Click" 
                                Width="130" Height="40" 
                                Background="Transparent" Foreground="#2E3137" 
                                BorderThickness="1" BorderBrush="#2E3137" 
                                Margin="10,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>