<Page x:Class="Human_Resources.Forms.frmApplicants"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Human_Resources.Forms"
      mc:Ignorable="d" 
      Title="Applicants Management" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Cabecera Azul -->
            <RowDefinition Height="*"/>
            <!-- Contenido Principal -->
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
            <DockPanel>
                <TextBlock x:Name="lblTitulo" 
                           Text="APPLICANTS MANAGEMENT" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Fila para los controles de filtro -->
                <RowDefinition Height="*"/>
                <!-- Fila para resultados o detalle -->
                <RowDefinition Height="Auto"/>
                <!-- Fila para los botones de filtro/acción -->
            </Grid.RowDefinitions>

            <!-- FILTROS DE BÚSQUEDA (Visibilidad controlada) -->
            <Border x:Name="bdrFilterControls" Grid.Row="0" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Fila 1 -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                        <TextBlock Text="Department" FontSize="14" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbDepartment"
                                  Height="30" Margin="0,5" FontSize="14" 
                                  DisplayMemberPath="Description" SelectedValuePath="Id"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                        <TextBlock Text="State" FontSize="14" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbState"
                                  Height="30" Margin="0,5" FontSize="14" 
                                  DisplayMemberPath="Description" SelectedValuePath="Id"
                                  SelectionChanged="cmbState_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="5">
                        <TextBlock Text="City" FontSize="14" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbCity"
                                  Height="30" Margin="0,5" FontSize="14" 
                                  DisplayMemberPath="Description" SelectedValuePath="Id"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="5">
                        <TextBlock Text="Status" FontSize="14" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbStatusFilter"
                                  Height="30" Margin="0,5" FontSize="13" 
                                  DisplayMemberPath="Description" SelectedValuePath="Id"/>
                    </StackPanel>

                    <!-- Fila 2 -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                        <TextBlock Text="Main Zip Code" FontSize="14" FontWeight="Bold"/>
                        <TextBox x:Name="txtZipCodeFilter"
                                 Height="25" Margin="0,5" FontSize="14" 
                                 MaxLength="5" PreviewTextInput="NumberValidationTextBox"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                        <TextBlock Text="Service Zip Code" FontSize="14" FontWeight="Bold"/>
                        <TextBox x:Name="txtServiceZipCodesFilter"
                                 Height="25" Margin="0,5" FontSize="14" 
                                 MaxLength="200" CharacterCasing="Upper"
                                 PreviewTextInput="ServiceZipCodesValidationTextBox"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2"  Grid.ColumnSpan="3" Margin="5">
                        <TextBlock Text="Applicant Name" FontSize="14" FontWeight="Bold"/>
                        <TextBox x:Name="txtFullNameFilter"
                                 Height="25" Margin="0,5" FontSize="14" 
                                 MaxLength="100" CharacterCasing="Upper"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENIDO DINÁMICO (Resultados o Detalle) -->
            <Grid Grid.Row="1" Margin="0,0,0,0">
                <!-- RESULTADOS DE BÚSQUEDA (DataGrid) -->
                <Grid x:Name="pnlResultadosBusqueda" Visibility="Collapsed">
                    <DataGrid x:Name="dgResultados" 
                          Grid.Row="0"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          SelectionMode="Single"
                          Background="Transparent" 
                          BorderThickness="0" 
                          GridLinesVisibility="None"
                          HeadersVisibility="Column" 
                          FontSize="13" 
                          RowHeight="25"
                          AlternationCount="2"
                          RowBackground="White"
                          AlternatingRowBackground="#F9F9FB">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="2*"/>
                            <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="2*"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusDescription}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- DETALLE DEL ASPIRANTE -->
                <Grid x:Name="pnlDetalle" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <!-- Para Observaciones -->
                            </Grid.RowDefinitions>

                            <!-- Fila 0 -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                                <TextBlock Text="Applicant ID" FontSize="14" FontWeight="Bold"/>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,2,0,5">
                                    <TextBlock x:Name="txtId" FontSize="16" Margin="0,5" Foreground="#333"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="5">
                                <TextBlock Text="Email" FontSize="14" FontWeight="Bold"/>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,2,0,5">
                                    <TextBlock x:Name="txtEmail" FontSize="16" Margin="0,5" Foreground="#333"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="3" Margin="5">
                                <TextBlock Text="Date Created" FontSize="14" FontWeight="Bold"/>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,2,0,5">
                                    <TextBlock x:Name="txtDateCreated" FontSize="16" Margin="0,5" Foreground="#333"/>
                                </Border>
                            </StackPanel>

                            <!-- Fila 1 -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                                <TextBlock Text="First Name" FontSize="14" FontWeight="Bold"/>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,2,0,5">
                                    <TextBlock x:Name="txtFirstName" FontSize="16" Margin="0,5" Foreground="#333"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="5">
                                <TextBlock Text="Last Name" FontSize="14" FontWeight="Bold"/>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,2,0,5">
                                    <TextBlock x:Name="txtLastName" FontSize="16" Margin="0,5" Foreground="#333"/>
                                </Border>
                            </StackPanel>

                            <!-- Fila 2 -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                                <TextBlock Text="Department" FontSize="14" FontWeight="Bold"/>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,2,0,5">
                                    <TextBlock x:Name="txtDepartment" FontSize="16" Margin="0,5" Foreground="#333"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2" Margin="5">
                                <TextBlock Text="State" FontSize="14" FontWeight="Bold"/>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,2,0,5">
                                    <TextBlock x:Name="txtState" FontSize="16" Margin="0,5" Foreground="#333"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="3" Margin="5">
                                <TextBlock Text="City" FontSize="14" FontWeight="Bold"/>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,2,0,5">
                                    <TextBlock x:Name="txtCity" FontSize="16" Margin="0,5" Foreground="#333"/>
                                </Border>
                            </StackPanel>

                            <!-- Fila 3 -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="5">
                                <TextBlock Text="Address" FontSize="14" FontWeight="Bold"/>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,2,0,5">
                                    <TextBlock x:Name="txtAddress" FontSize="16" Margin="0,5" Foreground="#333"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="3" Margin="5">
                                <TextBlock Text="Zip Code" FontSize="14" FontWeight="Bold"/>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,2,0,5">
                                    <TextBlock x:Name="txtZipCode" FontSize="16" Margin="0,5" Foreground="#333"/>
                                </Border>
                            </StackPanel>

                            <!-- Fila 4 -->
                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="1" Margin="5">
                                <TextBlock Text="Phone" FontSize="14" FontWeight="Bold"/>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,2,0,5">
                                    <TextBlock x:Name="txtPhone" FontSize="16" Margin="0,5" Foreground="#333"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Margin="5">
                                <TextBlock Text="Service Zip Codes" FontSize="14" FontWeight="Bold"/>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,2,0,5">
                                    <TextBlock x:Name="txtServiceZipCodes" FontSize="16" Margin="0,5" Foreground="#333"/>
                                </Border>
                            </StackPanel>

                            <!-- Fila 5 (Editable: Status) -->
                            <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                                <TextBlock Text="Status" FontSize="14" FontWeight="Bold"/>
                                <ComboBox x:Name="cmbStatusEdit"
                                          Height="30" Margin="0,5" FontSize="14" 
                                          DisplayMemberPath="Description" SelectedValuePath="Id"/>
                            </StackPanel>

                            <!-- Fila 6 (Observations) -->
                            <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="4" Margin="5">
                                <TextBlock Text="Observations" FontSize="14" FontWeight="Bold"/>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,2,0,5">
                                    <TextBlock x:Name="txtObservations" FontSize="16" Margin="0,5" Foreground="#333" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- BOTONES INFERIORES DE ACCIÓN (Buscar, Reset, Salir, Ver, Home, Actualizar Status, Eliminar, Back - visibilidad controlada por C#) -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="BtnBuscar" 
                        Content="_Search" 
                        Click="BtnBuscar_Click"
                        Width="120" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Background="#2ecc71" Foreground="White" Margin="5"/>
                <Button x:Name="BtnResetFiltro" 
                        Content="_Reset" 
                        Click="BtnResetFiltro_Click"
                        Width="120" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Background="#F39C12" Foreground="White" Margin="5"/>
                <Button x:Name="BtnSalirFiltro" 
                        Content="_Exit" 
                        Click="BtnSalirFiltro_Click"
                        Width="120" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Background="#95a5a6" Foreground="White" Margin="5"/>

                <!-- Botones de resultados, su visibilidad será controlada en C# -->
                <Button x:Name="BtnVerDetalle" 
                        Content="_View" 
                        Click="BtnVerDetalle_Click"
                        Width="120" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Background="#3498db" Foreground="White" Margin="5" Visibility="Collapsed"/>
                <Button x:Name="BtnHomeResultados" 
                        Content="_Home" 
                        Click="BtnHomeResultados_Click"
                        Width="120" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Background="#2ecc71" Foreground="White" Margin="5" Visibility="Collapsed"/>

                <!-- Botones de detalle, su visibilidad será controlada en C# -->
                <Button x:Name="BtnActualizarStatus" 
                        Content="_Update Status" 
                        Click="BtnActualizarStatus_Click"
                        Width="150" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Background="#3498db" Foreground="White" Margin="5" Visibility="Collapsed"/>
                <Button x:Name="BtnEliminarDetalle" 
                        Content="_Delete" 
                        Click="BtnEliminarDetalle_Click"
                        Width="120" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Background="#e74c3c" Foreground="White" Margin="5" Visibility="Collapsed"/>
                <Button x:Name="BtnBackDetalle" 
                        Content="_Back" 
                        Click="BtnBackDetalle_Click"
                        Width="120" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Background="#2ecc71" Foreground="White" Margin="5" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>