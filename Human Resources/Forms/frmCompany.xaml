<Page x:Class="Human_Resources.Forms.frmCompany"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Human_Resources.Forms"
      mc:Ignorable="d" 
      Title="Company Configuration" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Cabecera Azul -->
            <RowDefinition Height="*"/>
            <!-- Contenido de TabControl -->
            <RowDefinition Height="Auto"/>
            <!-- Botones de Acción -->
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
            <DockPanel>
                <TextBlock x:Name="lblTitulo" 
                           Text="COMPANY CONFIGURATION" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- AREA DE TRABAJO (TAB CONTROL) -->
        <TabControl x:Name="tcCompany" Grid.Row="1" Margin="10,10,10,0">
            <!-- TAB 1: COMPANY DETAILS -->
            <TabItem Header="Company Details" FontSize="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Name Company, Address -->
                            <RowDefinition Height="Auto"/>
                            <!-- State, City, Zip, Region -->
                            <RowDefinition Height="Auto"/>
                            <!-- Phone, Email -->
                            <RowDefinition Height="*"/>
                            <!-- Logo Upload -->
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                            <TextBlock Text="Name Company" FontSize="15" FontWeight="Bold"/>
                            <TextBox x:Name="txtName" 
                                     FontSize="15" MaxLength="50" CharacterCasing="Upper" 
                                     BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                     Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Margin="5">
                            <TextBlock Text="Full Address" FontSize="15" FontWeight="Bold"/>
                            <TextBox x:Name="txtAddress"
                                     FontSize="15" MaxLength="80" CharacterCasing="Upper" 
                                     BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                     Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                            <TextBlock Text="State" FontSize="15" FontWeight="Bold" />
                            <ComboBox x:Name="cmbState" 
                                      Margin="0,6" Height="30"
                                      DisplayMemberPath="Description" SelectedValuePath="Id"                                          
                                      SelectionChanged="cmbState_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                            <TextBlock Text="City" FontSize="15" FontWeight="Bold"/>
                            <ComboBox x:Name="cmbCity"
                                      Margin="0,6" Height="30"
                                      DisplayMemberPath="Description" SelectedValuePath="Id"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="5">
                            <TextBlock Text="Zip Code" FontSize="15" FontWeight="Bold"/>
                            <TextBox x:Name="txtZip"
                                     FontSize="15" MaxLength="5" CharacterCasing="Upper" 
                                     BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                     Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db"
                                     PreviewTextInput="NumberValidationTextBox"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="3" Margin="5">
                            <TextBlock Text="Region" FontSize="15" FontWeight="Bold"/>
                            <ComboBox x:Name="cmbRegion"
                                      Margin="0,6" Height="30"
                                      DisplayMemberPath="Description" SelectedValuePath="Id"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                            <TextBlock Text="Phone" FontSize="15" FontWeight="Bold"/>
                            <TextBox x:Name="txtPhone"
                                     FontSize="15" MaxLength="20" CharacterCasing="Upper" 
                                     BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                     Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Margin="5">
                            <TextBlock Text="Email" FontSize="15" FontWeight="Bold"/>
                            <TextBox x:Name="txtEmail"
                                     FontSize="15" MaxLength="50" CharacterCasing="Lower"
                                     BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                     Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Center">
                            <TextBlock Text="Company Logo" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Height="150" Width="150">
                                <Image x:Name="imgLogo" Stretch="Uniform" Margin="5"/>
                            </Border>
                            <Button x:Name="btnLoadLogo" Content="Upload Logo" Click="btnLoadLogo_Click" 
                                    Margin="0,10,0,0" Height="30" Background="#34495E" Foreground="White"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: EMAIL SETTINGS (NUEVA PESTAÑA) -->
            <TabItem Header="Email Settings" FontSize="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Mail Server, Port -->
                            <RowDefinition Height="Auto"/>
                            <!-- Mail Username, Password -->
                            <RowDefinition Height="Auto"/>
                            <!-- Enable SSL, Sender Name -->
                            <RowDefinition Height="*"/>
                            <!-- Spacer -->
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                            <TextBlock Text="Mail Server" FontSize="15" FontWeight="Bold"/>
                            <TextBox x:Name="txtMailServer" 
                                     FontSize="15" MaxLength="100" CharacterCasing="Lower" 
                                     BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                     Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="5">
                            <TextBlock Text="Mail Port" FontSize="15" FontWeight="Bold"/>
                            <TextBox x:Name="txtMailPort" 
                                     FontSize="15" MaxLength="5" PreviewTextInput="NumberValidationTextBox" 
                                     BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                     Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="3" Margin="5">
                            <TextBlock Text="Sender Name" FontSize="15" FontWeight="Bold"/>
                            <TextBox x:Name="txtSenderName" 
                                     FontSize="15" MaxLength="100" CharacterCasing="Upper" 
                                     BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                     Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                            <TextBlock Text="Mail Username" FontSize="15" FontWeight="Bold"/>
                            <TextBox x:Name="txtMailUsername" 
                                     FontSize="15" MaxLength="100" CharacterCasing="Lower" 
                                     BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                     Padding="2,5" VerticalContentAlignment="Center" SelectionBrush="#3498db" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="1" Margin="5">
                            <TextBlock Text="Mail Password" FontSize="15" FontWeight="Bold"/>
                            <PasswordBox x:Name="pbMailPassword" 
                                         FontSize="15" MaxLength="50"
                                         BorderThickness="0,0,0,1.5" BorderBrush="#BDC3C7" Background="Transparent"
                                         Padding="2,5" VerticalContentAlignment="Center" >
                                <PasswordBox.ToolTip>
                                    <TextBlock>Leave blank to keep current password. Enter new password to change it.</TextBlock>
                                </PasswordBox.ToolTip>
                            </PasswordBox>
                        </StackPanel>
                        <CheckBox x:Name="chkEnableSSL"
                                  Grid.Row="1" Grid.Column="3" 
                                  Content="Enable SSL"
                                  FontSize="15" VerticalAlignment="Center" FontWeight="Bold" Margin="5,30,5,5"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- BOTONES DE ACCIÓN INFERIORES (Siempre visibles) -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnUpdate" 
                        Content="_Update" 
                        Click="BtnUpdate_Click" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Width="130" Height="40" 
                        Background="#2E3137" Foreground="White" 
                        Margin="10,0"/>

                <Button x:Name="BtnExit" 
                        Content="_Exit" 
                        Click="BtnExit_Click" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Width="130" Height="40" 
                        Background="#95a5a6" Foreground="White" 
                        BorderThickness="0" Margin="10,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>