<Page x:Class="Human_Resources.Forms.frmCompany"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Company" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Cabecera Azul -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar con Buscador -->
            <RowDefinition Height="*"/>
            <!-- Contenido -->
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
            <DockPanel>
                <TextBlock x:Name="lblTitulo" 
                           Text="DEFINITION OF COMPANY" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="10">
            <DockPanel>
                <StackPanel x:Name="pnlSearch" Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="Search Name" 
                               FontSize="18"
                               VerticalAlignment="Center" 
                               Margin="0,0,10,0"/>
                    <TextBox x:Name="txtSearch" 
                             Width="400" Height="25" 
                             VerticalContentAlignment="Center" 
                             FontSize="18"
                             CharacterCasing="Upper" 
                             TextChanged="txtSearch_TextChanged"/>
                </StackPanel>
                <Button Content="🖨️" 
                                Style="{StaticResource MenuButtonStyle}" 
                                Name="btnPrint"
                                Click="BtnPrint_Click" 
                                Width="90" Height="35" 
                                FontSize="20" 
                                Background="#95a5a6" Foreground="White" 
                                BorderThickness="0" 
                                Margin="10,0"
                                HorizontalAlignment="Left"
                 />
            </DockPanel>
        </Border>

        <!-- AREA DE TRABAJO -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- LISTADO (DataGrid) -->
            <Grid x:Name="GridListado">
                <DataGrid x:Name="dgListado" 
                        AutoGenerateColumns="False" 
                        IsReadOnly="True" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        GridLinesVisibility="None"
                        HeadersVisibility="Column" 
                        FontSize="16" 
                        RowHeight="25"
                        AlternationCount="2"
                        RowBackground="White"
                        AlternatingRowBackground="#F9F9FB"
                        SelectionMode="Single">

                    <DataGrid.Columns>
                        <DataGridTextColumn     Header="Name Company" Binding="{Binding Name}"     Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>



            <StackPanel Grid.Row="1"
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom" >

                <Button x:Name="BtnAdd" 
                        Content="_Add" 
                        Click="BtnAdd_Click"
                        Width="90" Height="35" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Margin="5" 
                        Background="#2ecc71" Foreground="White" 
                        />
                <Button x:Name="BtnModify" 
                        Content="_Modify" 
                        Click="BtnModify_Click"
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Width="90" Height="35" 
                        Background="#3498db" Foreground="White" 
                        BorderThickness="0" Margin="5"
                        />
                <Button x:Name="BtnDelete" 
                        Click="BtnDelete_Click"
                        Content="_Delete" 
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Width="90" Height="35" 
                        Background="#e74c3c" Foreground="White" 
                        BorderThickness="0" Margin="5"
                        />
                <Button x:Name="BtnExit" 
                        Content="_Exit" 
                        Click="BtnExit_Click"
                        Style="{StaticResource MenuButtonStyle}"    
                        FontSize="15"
                        Width="90" Height="35" 
                        Background="#95a5a6" Foreground="White" 
                        BorderThickness="0" Margin="5"
                        />
            </StackPanel>


            <!-- EDICION (TabControl) -->
            <Grid x:Name="GridEdicion" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                        <Grid Margin="05">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0" 
                                        Grid.ColumnSpan="2" 
                                        Margin="5">

                                <TextBlock Text="Name Company" 
                                           FontSize="15"
                                           FontWeight="Bold"/>
                                <TextBox x:Name="txtName" 
                                         FontSize="15"
                                         MaxLength="40"
                                         CharacterCasing="Upper" 
                                         BorderThickness="0,0,0,1.5" 
                                         BorderBrush="#BDC3C7"
                                         Background="Transparent"
                                         Padding="2,5"
                                         VerticalContentAlignment="Center"
                                         SelectionBrush="#3498db" />
                            </StackPanel>


                            <StackPanel Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="4" Margin="5">
                                <TextBlock Text="Full Address"
                                           FontSize="15"
                                           FontWeight="Bold"/>
                                <TextBox x:Name="txtAddress"
                                         FontSize="15"
                                         MaxLength="80"
                                         CharacterCasing="Upper" 
                                         BorderThickness="0,0,0,1.5" 
                                         BorderBrush="#BDC3C7"
                                         Background="Transparent"
                                         Padding="2,5"
                                         VerticalContentAlignment="Center"
                                         SelectionBrush="#3498db" />

                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                                <TextBlock Text="State" FontSize="15" FontWeight="Bold" />
                                <ComboBox x:Name="cmbState" 
                                          Margin="0,6"
                                          BorderThickness="0,0,0,1.5" 
                                          BorderBrush="Transparent" 
                                          Background="Transparent"
                                          Padding="5,2"
                                          VerticalContentAlignment="Bottom"                                          
                                          SelectionChanged="cmbState_SelectionChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                                <TextBlock Text="City" 
                                           FontSize="15" 
                                           FontWeight="Bold"/>
                                <ComboBox x:Name="cmbCity"
                                          Margin="0,6"
                                          BorderThickness="0,0,0,1.5" 
                                          BorderBrush="Transparent" 
                                          Background="Transparent"
                                          Padding="5,2"
                                          VerticalContentAlignment="Bottom"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="5">
                                <TextBlock Text="Zip Code" FontSize="15" FontWeight="Bold"/>
                                <TextBox x:Name="txtZip"
                                         FontSize="15"
                                         MaxLength="5"
                                         CharacterCasing="Upper" 
                                         BorderThickness="0,0,0,1.5" 
                                         BorderBrush="#BDC3C7"
                                         Background="Transparent"
                                         Padding="2,5"
                                         VerticalContentAlignment="Center"
                                         SelectionBrush="#3498db"
                                         PreviewTextInput="NumberValidationTextBox"/>
                            </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="3" Margin="5">
                        <TextBlock Text="Region" 
                                           FontSize="15" 
                                           FontWeight="Bold"/>
                        <ComboBox x:Name="cmbRegion"
                                          Margin="0,6"
                                          BorderThickness="0,0,0,1.5" 
                                          BorderBrush="Transparent" 
                                          Background="Transparent"
                                          Padding="5,2"
                                          VerticalContentAlignment="Bottom"/>
                    </StackPanel>


                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="5">
                                <TextBlock Text="Phone" FontSize="15" FontWeight="Bold"/>
                                <TextBox x:Name="txtPhone"
                                         FontSize="15"
                                         MaxLength="20"
                                         CharacterCasing="Upper" 
                                         BorderThickness="0,0,0,1.5" 
                                         BorderBrush="#BDC3C7"
                                         Background="Transparent"
                                         Padding="2,5"
                                         VerticalContentAlignment="Center"
                                         SelectionBrush="#3498db" />
                            </StackPanel>


                            <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="5">
                                <TextBlock Text="e mail" FontSize="15" FontWeight="Bold"/>
                                <TextBox x:Name="txtEmail"
                                         FontSize="15"
                                         MaxLength="50"
                                         CharacterCasing="Lower"
                                         BorderThickness="0,0,0,1.5" 
                                         BorderBrush="#BDC3C7"
                                         Background="Transparent"
                                         Padding="2,5"
                                         VerticalContentAlignment="Center"
                                         SelectionBrush="#3498db" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.RowSpan="4" Grid.Column="4" Margin="10" VerticalAlignment="Top">
                                <TextBlock Text="Company Logo" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Height="150" Width="150">
                                    <Image x:Name="imgLogo" Stretch="Uniform" Margin="5"/>
                                </Border>
                                <Button x:Name="btnLoadLogo" Content="Upload Logo" Click="btnLoadLogo_Click" 
                                        Margin="0,10,0,0" Height="30" Background="#34495E" Foreground="White"/>
                            </StackPanel>

                </Grid>


                <Grid Grid.Row="1" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnUpdate" 
                                Content="_Update" 
                                Click="BtnUpdate_Click" 
                                Style="{StaticResource MenuButtonStyle}"    
                                FontSize="15"
                                Width="130" Height="40" 
                                Background="#2E3137" Foreground="White" 
                                Margin="10,0"/>

                        <Button x:Name="BtnHome" 
                                Content="_Home" 
                                Style="{StaticResource MenuButtonStyle}"    
                                FontSize="15"
                                Click="BtnVolverInicio_Click" 
                                Width="130" Height="40" 
                                Background="Transparent" Foreground="#2E3137" 
                                BorderThickness="1" BorderBrush="#2E3137" 
                                Margin="10,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>