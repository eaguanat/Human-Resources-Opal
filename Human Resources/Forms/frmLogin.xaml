<Window x:Class="Human_Resources.Forms.frmLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Login" Height="550" Width="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        Background="#F0F2F5"
        Icon="pack://application:,,,/Assets/Logo.ico"
        Loaded="FrmLogin_Loaded">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="cuerpo" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="5">
                            <AccessText x:Name="texto"
                                        Text="{TemplateBinding Content}" 
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"
                                        Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="cuerpo" Property="Background" Value="#D1D5DB"/>
                                <Setter TargetName="texto" Property="Foreground" Value="#9CA3AF"/>
                                <Setter TargetName="cuerpo" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="cuerpo" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="cuerpo" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#2E3137" BorderThickness="1" CornerRadius="8" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,30,0,20">
                <Image Source="pack://application:,,,/Assets/Logo.png"
                       Width="100" Height="100" 
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Row="1" 
                       Text="Secure System Login" 
                       FontSize="22" 
                       FontWeight="Bold" 
                       Foreground="#2E3137" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,30"/>

            <StackPanel x:Name="LoadingPanel" Grid.Row="2" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Height="10" Margin="50,0,50,10" Foreground="#3498db"/>
                <TextBlock Text="Verifying hardware access..." HorizontalAlignment="Center" Foreground="#7F8C8D" FontSize="14"/>
            </StackPanel>

            <StackPanel x:Name="LoginFieldsPanel" Grid.Row="2" Visibility="Collapsed">
                <StackPanel Margin="40,0,40,0">
                    <TextBlock Text="Username" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtName" Height="35" Padding="5" FontSize="16" BorderThickness="0,0,0,1.5" BorderBrush="#3498db" Background="#F8F8F8" VerticalContentAlignment="Center" MaxLength="20"/>

                    <TextBlock Text="Password" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,20,0,5"/>
                    <PasswordBox x:Name="pbPassword" Height="35" Padding="5" FontSize="16" BorderThickness="0,0,0,1.5" BorderBrush="#3498db" Background="#F8F8F8" VerticalContentAlignment="Center" MaxLength="50"/>

                    <TextBlock x:Name="txtError" Foreground="Red" FontSize="10" Margin="0,10,0,0" TextAlignment="Center" Visibility="Collapsed" TextWrapping="Wrap" Background="#FFF0F0" Padding="5" MinWidth="200" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,40">
                    <Button x:Name="BtnLogin" Content="_Login" Click="BtnLogin_Click" Style="{StaticResource MenuButtonStyle}" FontSize="16" Width="120" Height="40" Background="#2ecc71" Foreground="White" Margin="10,0"/>
                    <Button x:Name="BtnExit" Content="_Exit" Click="BtnExit_Click" Style="{StaticResource MenuButtonStyle}" FontSize="16" Width="120" Height="40" Background="#e74c3c" Foreground="White" Margin="10,0"/>
                </StackPanel>
            </StackPanel>
            
            <StackPanel x:Name="Version" Grid.Row="3" Margin="0,0,20,0">
                <TextBlock x:Name="lblVersion" 
                           Text="Versión: 0.0.0.0" 
                           Foreground="Gray" 
                           FontSize="10" 
                           VerticalAlignment="Bottom" 
                           HorizontalAlignment="Right" 
                           Margin="10,0,0,0"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>