<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Opal Hands</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @* Iconos de Bootstrap para los menús *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OpalHands.Web.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    @* Clases para mantener el footer abajo *@
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white py-3 shadow-sm">
            <div class="container d-flex align-items-center justify-content-start">
            
                @* BLOQUE DE MARCA (LOGO + TEXTO CENTRADO DEBAJO) *@
                <div class="d-flex flex-column align-items-center me-4">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none d-flex flex-column align-items-center">
                        <img src="/images/Opal Hands Logo.png" alt="Opal Hands" style="height: 60px;">
                        <span class="brand-text-under">Opal Hands</span>
                    </a>
                </div>

                @* MENÚ DE NAVEGACIÓN A LA IZQUIERDA *@
                <ul class="navbar-nav d-flex flex-row gap-3">
                    <li class="nav-item">
                        <a class="nav-link fw-bold text-dark" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-1"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-bold text-dark" asp-controller="Home" asp-action="About">
                            <i class="bi bi-people me-1"></i>About Us
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-bold text-dark" asp-controller="Home" asp-action="Contact">
                            <i class="bi bi-envelope me-1"></i>Contact Us
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-bold text-dark" asp-controller="Home" asp-action="Services">
                            <i class="bi bi-heart-pulse me-1"></i>Services
                        </a>
                    </li>
                </ul>
            
            </div>
        </nav>
        <div class="brand-divider"></div>
    </header>

    @* El contenedor principal ahora es fluido para que el diseño luzca mejor *@
    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    @* FOOTER CORREGIDO: Ubicado al final *@
    <footer class="border-top footer text-muted bg-white py-4 mt-auto">
        <div class="container text-center">
            <span class="small">&copy; 2026 - <strong>Opal Hands</strong> - Professional Home Health Care</span>
            <br />
            <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted small">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>