<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Opal Hands</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @* Iconos de Bootstrap *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OpalHands.Web.styles.css" asp-append-version="true" />

    <style>
            /* EFECTO OVER MOUSE (HOVER) PARA LA BOTONERA */
            .nav-custom-link {
                transition: all 0.3s ease; /* Transición suave */
                display: inline-block;
                color: #546E7A !important; /* Tu color base */
                text-decoration: none;
            }

                .nav-custom-link:hover {
                    color: #808080 !important; /* Cambio a Gris */
                    transform: scale(1.3); /* Crece un 30% (muy visible) */
                    font-weight: bold;
                    text-shadow: 0px 2px 4px rgba(0,0,0,0.1); /* Sombra suave al resaltar */
                }

            /* Ajuste para que los iconos no se peguen al crecer */
            .nav-item {
                padding: 0 10px;
            }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white py-3 shadow-sm">
            <div class="container d-flex align-items-center justify-content-start">
            
                @* BLOQUE DE MARCA (LOGO + TEXTO A LA DERECHA) *@
                <div class="d-flex align-items-center me-5">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none d-flex align-items-center">
                        <img src="/images/Opal Hands Logo.png" alt="Opal Hands" style="height: 110px;" class="me-3">
        
                        <div class="d-flex flex-column">
                            <span style="color: #546E7A; font-weight: bold; font-size: 1.8rem; line-height: 1;">
                                OPAL HANDS
                            </span>
                            <span style="color: #546E7A; font-weight: bold; font-size: 1.1rem; letter-spacing: 1px; text-transform: uppercase;">
                                Home Health Care
                            </span>
                        </div>
                    </a>
                </div>

                @* MENÚ DE NAVEGACIÓN CON EFECTO HOVER *@
                <ul class="navbar-nav d-flex flex-row gap-4">
                    <li class="nav-item">
                        <a class="nav-custom-link fw-bold" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-1"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-custom-link fw-bold" asp-controller="Home" asp-action="About">
                            <i class="bi bi-people me-1"></i>About Us
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-custom-link fw-bold" asp-controller="Home" asp-action="Contact">
                            <i class="bi bi-envelope me-1"></i>Contact Us
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-custom-link fw-bold" asp-controller="Home" asp-action="Services">
                            <i class="bi bi-heart-pulse me-1"></i>Services
                        </a>
                    </li>
                </ul>
            
            </div>
        </nav>
        <div class="brand-divider"></div>
    </header>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white py-4 mt-auto">
        <div class="container text-center">
            <span class="small">&copy; 2026 - <strong>Opal Hands</strong> - Professional Home Health Care</span>
            <br />
            <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted small">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>