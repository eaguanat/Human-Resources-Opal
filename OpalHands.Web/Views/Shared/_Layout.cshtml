<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Opal Hands</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OpalHands.Web.styles.css" asp-append-version="true" />

    <style>
        /* 1. ESTILOS BASE */
        .nav-custom-link {
            transition: all 0.3s ease;
            display: inline-block;
            color: #546E7A !important;
            text-decoration: none;
        }

        .nav-custom-link:hover {
            color: #808080 !important;
            transform: scale(1.3);
            font-weight: bold;
            text-shadow: 0px 2px 4px rgba(0,0,0,0.1);
        }

        .brand-title { color: #546E7A; font-weight: bold; font-size: 1.8rem; line-height: 1; }
        .brand-subtitle { color: #546E7A; font-weight: bold; font-size: 1.1rem; letter-spacing: 1px; text-transform: uppercase; }

        .hero-section {
            background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/images/tu-imagen-hero.jpg');
        }

        /* --- ESTILOS DEL SPINNER Y OVERLAY --- */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(84, 110, 122, 0.9);
            z-index: 9999;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .text-cyan {
            color: #1CE8FE !important;
        }

        /* 2. AJUSTES PARA PC */
        @@media (min-width: 992px) {
            .nav-item { padding: 0 15px; }
            .hero-section { 
                padding: 150px 0;
                background-position: center 25%;
            }
        }

        /* 3. AJUSTES PARA MÓVIL */
        @@media (max-width: 991px) {
            .navbar-brand img { height: 60px !important; }
            .brand-title { font-size: 1.2rem; }
            .brand-subtitle { font-size: 0.75rem; }

            .hero-section {
                padding: 140px 0 60px 0 !important;
                text-align: center;
                background-position: center center;
            }

            .hero-section h1.display-3 { font-size: 2rem !important; line-height: 1.2; }
            .hero-section p.lead { font-size: 0.95rem !important; margin-bottom: 2rem !important; }

            .hero-section .d-flex {
                flex-direction: column;
                gap: 12px !important;
                align-items: center;
            }

            .hero-section .btn { width: 85%; padding: 12px !important; }

            .nav-item { padding: 12px 0; border-bottom: 1px solid rgba(0,0,0,0.05); }
            .navbar-collapse { background-color: #fff; padding: 15px; border-radius: 8px; margin-top: 10px; box-shadow: 0px 4px 10px rgba(0,0,0,0.05); }
            #services-overview h2 { font-size: 1.6rem; }
            .service-card { margin-bottom: 10px; }
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

    <div id="loadingOverlay" class="loading-overlay d-none">
        <div class="text-center">
            <div id="loadingSpinner" class="spinner-border text-cyan mb-3" role="status" style="width: 3.5rem; height: 3.5rem;">
                <span class="visually-hidden">Loading...</span>
            </div>
            @* Icono de error que empieza oculto *@
            <div id="errorIcon" class="d-none mb-3">
                <i class="bi bi-exclamation-triangle-fill text-warning" style="font-size: 3.5rem;"></i>
            </div>
            <h5 id="overlayTitle" class="text-white fw-bold">Connecting with Opal Hands...</h5>
            <p id="overlayText" class="text-white-50">Please wait while we secure your data.</p>
        </div>
    </div>

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white py-3 shadow-sm">
            <div class="container">
                <a asp-controller="Home" asp-action="Index" class="navbar-brand d-flex align-items-center">
                    <img src="/images/Opal Hands Logo.png" alt="Opal Hands" style="height: 70px;" class="me-2 logo-mobile">
                    <div class="d-flex flex-column">
                        <span class="brand-title">OPAL HANDS</span>
                        <span class="brand-subtitle">Home Health Care</span>
                    </div>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarOpal" aria-controls="navbarOpal" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarOpal">
                    <ul class="navbar-nav ms-auto mt-3 mt-lg-0 gap-lg-4 text-center">
                        <li class="nav-item">
                            <a class="nav-custom-link fw-bold" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-custom-link fw-bold" asp-controller="Home" asp-action="About">
                                <i class="bi bi-people me-1"></i>About Us
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-custom-link fw-bold" asp-controller="Home" asp-action="Contact">
                                <i class="bi bi-envelope me-1"></i>Contact Us
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-custom-link fw-bold" asp-controller="Home" asp-action="Services">
                                <i class="bi bi-heart-pulse me-1"></i>Services
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white py-4 mt-auto">
        <div class="container text-center">
            <span class="small">&copy; 2026 - <strong>Opal Hands</strong> - Professional Home Health Care</span>
            <br />
            <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted small">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        // Función global para manejar el error y redirección (Estrategia Sensei)
        window.showConnectionError = function() {
            const overlay = document.getElementById('loadingOverlay');
            const spinner = document.getElementById('loadingSpinner');
            const errorIcon = document.getElementById('errorIcon');
            const title = document.getElementById('overlayTitle');
            const text = document.getElementById('overlayText');

            if (overlay) {
                overlay.classList.remove('d-none');
                spinner.classList.add('d-none'); // Quitamos el spinner
                errorIcon.classList.remove('d-none'); // Ponemos el icono de aviso
                
                title.innerText = "Connection Error. Please try again.";
                text.innerText = "Error de Conexión. Reintente.";

                // Delay de 3 segundos y para el Home
                setTimeout(function() {
                    window.location.href = '/'; 
                }, 3000);
            }
        };

        document.addEventListener("DOMContentLoaded", function () {
            const links = document.querySelectorAll('.nav-custom-link, .navbar-brand, .btn-outline-light, .btn-lg');
            const overlay = document.getElementById('loadingOverlay');

            links.forEach(link => {
                link.addEventListener('click', function () {
                    if (this.href && !this.href.includes('#')) {
                        overlay.classList.remove('d-none');
                    }
                });
            });

            // Capturar errores globales de AJAX (JQuery)
            $(document).ajaxError(function() {
                window.showConnectionError();
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>