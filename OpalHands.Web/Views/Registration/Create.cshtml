@model OpalHands.Web.Models.tblApplicants

@{
    ViewData["Title"] = "Registration / Registro";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .required-field {
        text-transform: uppercase;
    }
    
    .btn-opal-interactive, .btn-opal-final {
        transition: all 0.3s ease;
        background-color: #ffffff;
        border: 2px solid #546E7A;
        color: #546E7A;
    }

        .btn-opal-interactive:hover, .btn-opal-final:not(:disabled):hover {
            background-color: #0B8FB1 !important;
            border-color: #0B8FB1 !important;
            color: #ffffff !important;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(11, 143, 177, 0.3);
        }

        .btn-opal-final:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            border-color: #ccc;
        }

    /* Resaltado suave para campos obligatorios */
    .form-control:focus, .form-select:focus {
        border-color: #1CE8FE;
        box-shadow: 0 0 0 0.25 hide-rem rgba(28, 232, 254, 0.25);
    }
</style>

<div class="container mt-4 shadow-sm p-4 bg-white rounded">
    <div class="text-center mb-4">
        <h2 class="fw-bold" style="color: #546E7A;">Opal Hands Home Health Care</h2>
        <h4 class="text-muted">Application Form / Formulario de Aplicación</h4>
    </div>

    <form asp-action="Create" id="mainForm">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        @* STEP 1: ACCOUNT SETUP *@
        <div class="card mb-4 border-0 shadow-sm">
            <div class="p-3 text-white fw-bold" style="background-color: #0B8FB1; border-radius: 8px 8px 0 0;">
                Step 1: Account Setup / Paso 1: Configuración de Cuenta
            </div>
            <div class="card-body border">
                <div class="row align-items-end">
                    <div class="col-md-5">
                        <label class="form-label fw-bold">Email / Correo <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input asp-for="Email" id="txtEmail" class="form-control" placeholder="example@mail.com" />
                            <span class="input-group-text bg-white border-start-0 d-none" id="check-Email"><i class="bi bi-check-circle-fill text-success"></i></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Password / Contraseña <span class="text-danger">*</span></label>
                        <input asp-for="Password" id="txtPass" type="password" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <button type="button" id="btnVerify" class="btn fw-bold px-4 rounded-pill btn-opal-interactive w-100">
                            Verify / Verificar
                        </button>
                    </div>
                </div>
                <div id="emailMessage" class="mt-2 fw-bold text-danger" style="display:none;"></div>
            </div>
        </div>

        @* STEP 2: PERSONAL INFO *@
        <div id="secondStep" style="display: none;">
            <div class="row mb-3">
                <div class="col-md-12">
                    <label class="form-label fw-bold">Position / Posición a la que aplica <span class="text-danger">*</span></label>
                    <select asp-for="idDepartment" id="ddlDept" class="form-select border-info shadow-sm" asp-items="@(ViewBag.Departments as SelectList)">
                        <option value="">-- Select Position / Seleccione Posición --</option>
                    </select>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">First Name / Nombre <span class="text-danger">*</span></label>
                    <input asp-for="FirstName" class="form-control required-field" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Last Name / Apellido <span class="text-danger">*</span></label>
                    <input asp-for="LastName" class="form-control required-field" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Phone / Teléfono <span class="text-danger">*</span></label>
                    <input asp-for="Phone" class="form-control required-field" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-12">
                    <label class="form-label fw-bold">Address / Dirección <span class="text-danger">*</span></label>
                    <input asp-for="Address" class="form-control required-field" />
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-4">
                    <label class="form-label fw-bold">State / Estado <span class="text-danger">*</span></label>
                    <select asp-for="idGeoState" id="ddlState" class="form-select required-field" asp-items="@(ViewBag.States as SelectList)">
                        <option value="">-- State --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">City / Ciudad <span class="text-danger">*</span></label>
                    <select asp-for="idGeoCity" id="ddlCity" class="form-select required-field">
                        <option value="">-- City --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Zip Code <span class="text-danger">*</span></label>
                    <input asp-for="ZipCode" class="form-control required-field" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Service Areas (Zip Codes) <span class="text-danger">*</span></label>
                    <input asp-for="ServiceZipCodes" class="form-control required-field" placeholder="Example: 33625, 33626..." />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Observations / Observaciones</label>
                    <textarea asp-for="Observations" class="form-control" rows="2"></textarea>
                </div>
            </div>

            <div class="text-end mt-4">
                <button type="submit" id="btnFinalize" class="btn fw-bold px-5 btn-lg rounded-pill btn-opal-final" disabled>
                    Finish Application / Finalizar Aplicación
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {

        // Capturamos el overlay del Layout
        const overlay = document.getElementById('loadingOverlay');

        // 1. EVENTO CLICK PARA VERIFICAR
        $('#btnVerify').click(function() {
        var email = $('#txtEmail').val();
        var pass = $('#txtPass').val();

        if(email === "" || pass === "") {
        alert("Please enter Email and Password.");
        return;
        }

        // Mostramos el spinner mientras verificamos el correo
        if (overlay) overlay.classList.remove('d-none');

        $.get('/Registration/CheckEmail', { email: email }, function(data) {
        // Ocultamos el spinner al recibir respuesta
        if (overlay) overlay.classList.add('d-none');

        if(data.isDuplicate) {
        $('#emailMessage').text("Email already registered / Correo ya registrado").show();
        } else {
        $('#emailMessage').hide();
                        
        $('#txtEmail, #txtPass').prop('readonly', true).addClass('bg-light');
        $('#btnVerify').prop('disabled', true)
        .text('Verified / Verificado')
        .css('opacity', '0.7');
                        
        $('#check-Email').removeClass('d-none');
        $('#secondStep').fadeIn();
        }
        }).fail(function() {
        if (overlay) overlay.classList.add('d-none');
        alert("Error connecting to server. Please try again.");
        });
        });

        // 2. CASCADA DE CIUDADES
        $('#ddlState').change(function() {
        var stateId = $(this).val();
        var $citySelect = $('#ddlCity');
        $citySelect.empty().append('<option value="">-- Loading... --</option>');

        if (stateId) {
        $.get('/Registration/GetCities', { stateId: stateId }, function(data) {
        $citySelect.empty().append('<option value="">-- Select City --</option>');
        $.each(data, function(i, city) {
        $citySelect.append($('<option>', { value: city.id, text: city.description }));
        });
        validateAll(); // Re-validar al cargar ciudades
        });
        }
        });

        // 3. FUNCIÓN DE VALIDACIÓN
        function validateAll() {
        var allFilled = true;
        $('.required-field').each(function() {
        if($(this).val() === "" || $(this).val() === null) {
        allFilled = false;
        }
        });
        if($('#ddlDept').val() === "") {
        allFilled = false;
        }
        $('#btnFinalize').prop('disabled', !allFilled);
        }

        // 4. DISPARADORES DE VALIDACIÓN
        $(document).on('input change blur', '.required-field, #ddlDept', function() {
        validateAll();
        });

        // 5. ACTIVAR SPINNER AL ENVIAR FORMULARIO FINAL
        $('#mainForm').submit(function() {
        if (overlay) {
        // Cambiamos el texto del spinner para este paso específico
        const overlayText = overlay.querySelector('h5');
        if (overlayText) overlayText.innerText = "Connecting with Opal Hands...";
        overlay.classList.remove('d-none');
        }
        });

        });
    </script>
}