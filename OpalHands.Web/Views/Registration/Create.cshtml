@model OpalHands.Web.Models.tblApplicants

@{
    ViewData["Title"] = "Registro / Registration";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    /* Obliga visualmente a que todo se vea en mayúsculas en los inputs */
    .required-field {
        text-transform: uppercase;
    }
</style>

<div class="container mt-4 shadow-sm p-4 bg-white rounded">
    <div class="text-center mb-4">
        <h2 class="text-success fw-bold">Opal Hands Home Health Care</h2>
        <h4 class="text-muted">Application Form / Formulario de Aplicación</h4>
    </div>

    <form asp-action="Create" id="mainForm">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white fw-bold">
                Step 1: Account Setup / Paso 1: Configuración de Cuenta
            </div>
            <div class="card-body">
                <div class="row align-items-end">
                    <div class="col-md-5">
                        <label class="form-label fw-bold">Email / Correo <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input asp-for="Email" id="txtEmail" class="form-control" placeholder="example@mail.com" />
                            <span class="input-group-text bg-white border-start-0 d-none" id="check-Email"><i class="bi bi-check-circle-fill text-success"></i></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Password / Contraseña <span class="text-danger">*</span></label>
                        <input asp-for="Password" id="txtPass" type="password" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <button type="button" id="btnVerify" class="btn btn-primary w-100 fw-bold">Verify / Verificar</button>
                    </div>
                </div>
                <div id="emailMessage" class="mt-2 fw-bold text-danger" style="display:none;"></div>
            </div>
        </div>

        <div id="secondStep" style="display: none;">
            
            <div class="row mb-3">
                <div class="col-md-12">
                    <label class="form-label fw-bold">Position you are applying for / Posición a la que aplica <span class="text-danger">*</span></label>
                    <select asp-for="idDepartment" id="ddlDept" class="form-select border-success shadow-sm"
                            asp-items="@(ViewBag.Departments as SelectList)">
                        <option value="">-- Select Position / Seleccione Posición --</option>
                    </select>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">First Name / Nombre <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input asp-for="FirstName" class="form-control required-field" />
                        <span class="input-group-text d-none"><i class="bi bi-check-circle-fill text-success"></i></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Last Name / Apellido <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input asp-for="LastName" class="form-control required-field" />
                        <span class="input-group-text d-none"><i class="bi bi-check-circle-fill text-success"></i></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Phone / Teléfono <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input asp-for="Phone" class="form-control required-field" />
                        <span class="input-group-text d-none"><i class="bi bi-check-circle-fill text-success"></i></span>
                    </div>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-12">
                    <label class="form-label fw-bold">Address / Dirección <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input asp-for="Address" class="form-control required-field" />
                        <span class="input-group-text d-none"><i class="bi bi-check-circle-fill text-success"></i></span>
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-4">
                    <label class="form-label fw-bold">State / Estado <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <select asp-for="idGeoState" id="ddlState" class="form-select required-field" asp-items="@(ViewBag.States as SelectList)">
                            <option value="">-- State --</option>
                        </select>
                        <span class="input-group-text d-none"><i class="bi bi-check-circle-fill text-success"></i></span>
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">City / Ciudad <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <select asp-for="idGeoCity" id="ddlCity" class="form-select required-field">
                            <option value="">-- City --</option>
                        </select>
                        <span class="input-group-text d-none"><i class="bi bi-check-circle-fill text-success"></i></span>
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Zip Code <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input asp-for="ZipCode" class="form-control required-field" />
                        <span class="input-group-text d-none"><i class="bi bi-check-circle-fill text-success"></i></span>
                    </div>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Service Areas (Zip Codes) / Áreas de Servicio <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input asp-for="ServiceZipCodes" class="form-control required-field" placeholder="Example: 33625, 33626..." />
                        <span class="input-group-text d-none"><i class="bi bi-check-circle-fill text-success"></i></span>
                    </div>
                    <small class="text-muted">List the Zip Codes you can cover / Liste los Zip Codes que puede cubrir.</small>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Additional Observations / Observaciones Adicionales</label>
                    <textarea asp-for="Observations" class="form-control required-field" rows="2" placeholder="Brief notes..."></textarea>
                </div>
            </div>

            <div class="text-end">
                <button type="submit" id="btnFinalize" class="btn btn-secondary btn-lg px-5 shadow" disabled>
                    Finish Application / Finalizar Aplicación
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            
        // 1. VERIFICACIÓN DE EMAIL
        $('#btnVerify').click(function() {
        var email = $('#txtEmail').val();
        var pass = $('#txtPass').val();

        if(email == "" || pass == "") {
        alert("Please fill Email and Password / Por favor llene Email y Clave");
        return;
        }

        $.get('/Registration/CheckEmail', { email: email }, function(data) {
        if(data.isDuplicate) {
        $('#emailMessage').text("We are analyzing your application; we will contact you via email. / Estamos analizando su propuesta; lo contactaremos a través de su correo electrónico.").show();
        $('#secondStep').hide();
        } else {
        $('#emailMessage').hide();
        $('#txtEmail, #txtPass, #btnVerify').prop('readonly', true).addClass('bg-light');
        $('#check-Email').removeClass('d-none');
        $('#secondStep').fadeIn();
        }
        });
        });

        // 2. CASCADA DE CIUDADES
        $('#ddlState').change(function() {
        var stateId = $(this).val();
        var $citySelect = $('#ddlCity');
        $citySelect.empty().append('<option value="">-- Loading / Cargando... --</option>');

        if (stateId) {
        $.get('/Registration/GetCities', { stateId: stateId }, function(data) {
        $citySelect.empty().append('<option value="">-- Select City / Seleccione --</option>');
        $.each(data, function(i, city) {
        $citySelect.append($('<option>', { value: city.id, text: city.description }));
        });
        });
        } else {
        $citySelect.empty().append('<option value="">-- City --</option>');
        }
        });

        // 3. VALIDACIÓN VISUAL (Checks Verdes)
        $('.required-field, #ddlDept, #ddlState, #ddlCity').on('input change blur', function() {
        var input = $(this);
        var container = input.closest('.col-md-4, .col-md-12, .col-md-6, .input-group');
        var icon = container.find('.bi-check-circle-fill').parent();

        if(input.val() !== "" && input.val() !== null) {
        icon.removeClass('d-none');
        } else {
        icon.addClass('d-none');
        }
        validateAll();
        });

        // 4. LIMPIEZA AUTOMÁTICA (MAYÚSCULAS Y SIN TILDES)
        $('.required-field').on('blur', function() {
        var str = $(this).val();
        if (str) {
        var cleanStr = str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toUpperCase();
        $(this).val(cleanStr);
        }
        });

        function validateAll() {
        var allFilled = true;
        // Solo validamos los campos que tienen la clase required-field
        $('.required-field').each(function() {
        if($(this).val() === "" || $(this).val() === null) allFilled = false;
        });
            
        // También validamos el departamento
        if($('#ddlDept').val() === "") allFilled = false;

        if(allFilled) {
        $('#btnFinalize').removeClass('btn-secondary').addClass('btn-success').prop('disabled', false);
        } else {
        $('#btnFinalize').addClass('btn-secondary').removeClass('btn-success').prop('disabled', true);
        }
        }
        });
    </script>
}