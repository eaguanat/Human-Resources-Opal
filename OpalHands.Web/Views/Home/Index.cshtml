@{
    ViewData["Title"] = "Opal Hands | Home Health Care";
}

@* --- SECCIÓN HERO (ESTILO QUIRÚRGICO) --- *@
<div class="hero-container">
    <section class="hero-section d-flex align-items-center"
             style="background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('@Url.Content("~/images/hero-opal-hands-tampa.webp")'); background-size: cover; background-position: center;">
        <div class="container">
            <div class="row">
                <div class="col-lg-7 text-white animate__animated animate__fadeInLeft">
                    
                    <h1 class="display-3 fw-bold mb-3">
                        Expert In-Home Care <span class="text-cyan">Tailored to Your Needs.</span>
                    </h1>
                    
                    <p class="lead mb-5 text-shadow-sm fs-5 text-white-90" style="max-width: 600px;">
                        At Opal Hands, we deploy specialized, professional care directly
                        to your home. We are committed to your comfort and dignity,
                        because your family deserves the best—right where they need us.
                    </p>
                    
                    <div class="d-flex gap-3">
                        @* Cambiamos el color sólido por 'outline-light' *@
                        <a asp-controller="Registration" asp-action="Create" class="btn btn-outline-light rounded-pill px-4 fw-bold">
                            <i class="bi bi-pencil-square me-2"></i>Apply Online Now
                        </a>

                        <a asp-action="Services" class="btn btn-outline-light rounded-pill px-4 fw-bold">
                            Our Services
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </section>
</div>

@* --- SECCIÓN PREVIA DE SERVICIOS (EL TRIDENTE) --- *@
<section id="services-overview" class="py-5 bg-white">
    <div class="container py-4 text-center">
        <h2 class="fw-bold mb-5" style="color: #546E7A;">Professional Care at Home</h2>
        
        <div class="row g-4">
            
            @* Bloque 1 *@
            <div class="col-md-4">
                <div class="service-card p-4 h-100 shadow-sm border-0">
                    <div class="icon-box mb-3">
                        <i class="bi bi-heart-pulse fs-1 text-cyan"></i>
                    </div>
                    <h3 class="fw-bold" style="color: #546E7A;">Skilled Nursing</h3>
                    <p class="text-muted">
                        Professional medical care directed by registered nurses.
                    </p>
                </div>
            </div>

            @* Bloque 2 *@
            <div class="col-md-4">
                <div class="service-card p-4 h-100 shadow-sm border-0">
                    <div class="icon-box mb-3">
                        <i class="bi bi-person-walking fs-1 text-cyan"></i>
                    </div>
                    <h3 class="fw-bold" style="color: #546E7A;">Rehabilitative Therapies</h3>
                    <p class="text-muted">
                        Physical, occupational, and speech therapy for independence.
                    </p>
                </div>
            </div>

            @* Bloque 3 *@
            <div class="col-md-4">
                <div class="service-card p-4 h-100 shadow-sm border-0">
                    <div class="icon-box mb-3">
                        <i class="bi bi-shield-check fs-1 text-cyan"></i>
                    </div>
                    <h3 class="fw-bold" style="color: #546E7A;">Long-Term Support</h3>
                    <p class="text-muted">
                        Personalized assistance with daily activities and peace of mind.
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>