@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-uppercase" style="color: #546E7A; letter-spacing: 3px;">Our Organizational Culture</h2>
        <div class="brand-divider mx-auto" style="width: 100px;"></div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4 custom-about-card">
                <div class="icon-circle mx-auto mb-3">
                    <i class="bi bi-rocket-takeoff fs-2 text-white"></i>
                </div>
                <h3 class="fw-bold mb-3" style="color: #546E7A;">MISSION</h3>
                <p class="text-muted fs-5 px-2">
                    Our Mission is to be an agent of change that transforms the quality of life of our patients and their families,
                    being their trusted provider of home care through empathetic and kind support of high quality and professionalism.
                    We aim to promote in our employees the holistic principle of service that provides comprehensive, personalized,
                    and compassionate care; creating value for our healthcare partners and the institutions that fund our care.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4 custom-about-card">
                <div class="icon-circle mx-auto mb-3">
                    <i class="bi bi-eye fs-2 text-white"></i>
                </div>
                <h3 class="fw-bold mb-3" style="color: #546E7A;">VISION</h3>
                <p class="text-muted fs-5 px-2">
                    Our Vision is to be the preferred choice for patients and families seeking home care focused on human excellence
                    and quality of life, providing peace of mind, overall well-being, and trust through a team of qualified,
                    compassionate caregivers committed to the dignity of every person.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4 custom-about-card">
                <div class="icon-circle mx-auto mb-3">
                    @* Subí este a fs-2 para que el escudo destaque, pero puedes dejarlo fs-5 si prefieres *@
                    <i class="bi bi-shield-check fs-2 text-white"></i>
                </div>
                <h3 class="fw-bold mb-3" style="color: #546E7A;">VALUES</h3>
        
                @* CAMBIO CLAVE: Reemplacé 'small' por 'fs-5' *@
                <ul class="list-unstyled text-muted fs-5 text-start d-inline-block mx-auto">
                    <li><i class="bi bi-check2-circle me-2 text-info"></i>Service to Life</li>
                    <li><i class="bi bi-check2-circle me-2 text-info"></i>Quality of Life</li>
                    <li><i class="bi bi-check2-circle me-2 text-info"></i>Humanism</li>
                    <li><i class="bi bi-check2-circle me-2 text-info"></i>Kindness and Empathy</li>
                    <li><i class="bi bi-check2-circle me-2 text-info"></i>Respect</li>
                    <li><i class="bi bi-check2-circle me-2 text-info"></i>Integrity and Transparency</li>
                    <li><i class="bi bi-check2-circle me-2 text-info"></i>Responsibility and Commitment</li>
                    <li><i class="bi bi-check2-circle me-2 text-info"></i>Safety</li>
                    <li><i class="bi bi-check2-circle me-2 text-info"></i>Professionalism and Competence</li>
                </ul>
            </div>
        </div>
    </div>
</div>