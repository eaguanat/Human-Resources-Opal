@{
    ViewData["Title"] = "Session Expired";
}

<div class="container mt-5 text-center">
    <div class="py-5 shadow-sm bg-white rounded border">
        <i class="bi bi-clock-history text-warning" style="font-size: 4rem;"></i>
        <h2 class="fw-bold mt-3" style="color: #546E7A;">Session Expired / Sesión Expirada</h2>
        <p class="text-muted px-4">
            For your security, the session was closed due to 10 minutes of inactivity.<br />
            Por su seguridad, se cerró la sesión tras 10 minutos de inactividad.
        </p>
        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-lg rounded-pill px-5"
                   style="background-color: #0B8FB1; color: white;">
                Return to Home / Volver al Inicio
            </a>
        </div>
    </div>
</div>